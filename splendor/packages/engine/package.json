{
  "name": "@splendor/engine",
  "version": "0.1.0",
  "description": "Pure, deterministic Splendor rules engine, data validator, and invariant fuzz tests.",
  "license": "MIT",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "gen:data": "node scripts/gen-data.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "fuzz": "npm run build && node --test dist/test/fuzz.test.js"
  }
}
